Table mobile_training_students{
  id integer [primary key]
  user_id integer
  payment_id integer
  training_program_id integer
  training_level_id integer
  name varchar
  gender enum('male','female')
  phone varchar
  email varchar
  age integer
  address text
  payment_image_url text
  payment_public_id text
  create_at timestamp
}

Table mobile_training_student_time_slots{
  id integer [primary key]
  mobile_training_students_id integer
  training_schedule_time_slot_id integer
  create_at timestamp
}

Table admin_training_students{
  id integer [primary key]
  payment_id integer
  training_program_id integer
  training_level_id integer
  name varchar
  gender enum('male','female')
  age integer
  phone varchar
  email varchar
  payment_image_url text
  payment_public_id text
  create_at timestamp_stamp
}

Table admin_training_student_time_slots{
  id integer [primary key]
  admin_training_students_id integer
  training_schedule_time_slot_id integer
  create_at timestamp
}

Table training_level{
  id integer [primary key]
  training_program_id integer
  title_level varchar
  description varchar
  price integer
  create_at timestamp
}

Table training_schedule_time_slots{
  id integer [primary key]
  training_schedule_day_id integer
  training_program_id integer
  training_level_id integer
  start_time time
  end_time time
}

Table training_schedule_days{
  id integer [primary key]
  day eum('Mon','Tue','Wed','Thu','Fri','Sat','Sun')
  create_at timestamp
}

Table training_program{
  id integer [primary key]
  category_card_image_url text
  category_card_public_id text
  main_program_banner_image_url text
  main_program_banner_public_id text
  learning_image_url text
  learning_public_id text
  learning_description text
  main_title varchar
  title varchar
  about_title varchar
  details text
  create_at timestamp
}

Table training_coach{
  id integer [primary key]
  training_program_id integer
  coach_image_url text
  coach_public_id text
  instructor_name varchar
  biography varchar
  create_at timestamp
}

//Venue

Table court_time_slot{
  id integer [primary key]
  court_id integer
  start_time time
  end_time time
  available boolean
  create_at timestamp
}

Table court{
  id integer [primary key]
  venue_id integer
  court_name varchar
  hourly_price integer
  open_at time
  close_at time
  about_court text
  court_active boolean
  create_at timestamp
}

Table court_gallery{
  id integer [primary key]
  court_id integer
  court_image_url text
  court_public_id text
  create_at timestamp
}

Table venue{
  id integer [primary key]
  venue_name varchar
  price integer
  venue_image_url text
  venue_public_id text
  available boolean
  create_at timestamp
}

Table service{
  id integer [primary key]
  venue_id integer
  name varchar
  create_at timestamp
}

Table rule{
  id integer [primary key]
  venue_id integer
  name varchar
  description text
  create_at timestamp
}

Table pros{
  id integer [primary key]
  court_id integer
  name varchar
  detail text
  create_at timestamp
}

Table cons{
  id integer [primary key]
  court_id integer
  name varchar
  create_at timestamp
}

Table equipment{
  id integer [primary key]
  venue_id integer
  product_name varchar
  rental_price integer
  qty_total integer
  create_at timestamp
}

//Mobile_Booking

Table mobile_rental_booking{
  id integer [primary key]
  user_id integer
  venue_id integer
  court_id integer
  payment_id integer
  name varchar
  phone integer
  rental integer
  amount integer
  remark varchar
  date date
  payment_image_url text
  payment_public_id text
  create_at timestamp
}

Table mobile_rental_time_slot{
  id integer [primary key]
  mobile_rental_booking_id integer
  court_time_slot_id integer
}

Table mobile_rental_booking_equipment{
  id integer [primary key]
  equipment_id integer
  mobile_rental_booking_id integer
  quantity integer
  department varchar
  price integer
  total integer
  create_at timestamp
}

//Admin_Booking

Table admin_booking{
  id integer [primary key]
  venue_id integer
  court_id integer
  payment_id integer
  reciept_no varchar
  price integer
  amount integer
  date date
  payment_image_url varchar
  payment_public_id varchar
  create_at timestamp
}

Table admin_booking_time_slot{
  id integer [ primary key]
  booking_id integer
  court_time_slot_id integer
}

Table admin_booking_equipment{
  id integer [primary key]
  booking_id integer
  equipment_id integer
  quantity integer
  department varchar
  price integer
  total integer
  create_at timestamp
}


Table roles{
  id integer [primary key]
  role_name varchar
}

Table staff {
  id integer [primary key]
  role_id integer
  name varchar
  email varchar
  status enum('active','inactive')
  password varchar
}


//Canteen

Table canteen_order{
  id integer [primary key]
  payment_id integer
  reciept_no varchar
  payment_image_url text
  payment_public_id text
  amount integer
  create_at timestamp
}

Table canteen_order_item{
  id integer [primary key]
  canteen_order_id integer
  canteen_product_id integer
  price integer
  total integer
  quantity integer
  create_at timestamp
}

Table canteen_category{
  id interger [primary key]
  name varchar
  create_at timestamp
}

Table canteen_products{
  id integer [primary key]
  category_id integer
  name varchar
  price varchar
  image_url text
  public_url text
  create_at timestamp
  available bool
}


Table Enrollment {
  id integer [primary key]
  user_id int
  name varchar
  gender varchar
  phone varchar
  email varchar
  age integer
  address varchar
  emergencyContentNumber varchar
  courseSelection varchar
  trainingLevel varchar
  trainingSchedule varchar
}

