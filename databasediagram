  size varchar
  type varchar
  weight varchar
  stock int
  date date
  create_at timestamp
}


Table product_images {
  id integer [primary key]
  product_id integer
  image_url text
  public_id text
  create_at timestamp
}


Table product_tags {
  product_id integer [primary key]
  tag_id integer [primary key]
}
